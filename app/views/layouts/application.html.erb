<!DOCTYPE html>
<html>

<head>
  <title>Seanbase</title>
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
  <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
</head>

<body>

  <a href="#" class="button" onclick="toggleLanguage('Japanese')">日本語</a>

  <div class="main-container">
    <div class="infobox">
      <div class="blurbox">
        <h1 id="name" lang="en">Sean Luse</h1>
                <h1 id="name" lang="ja">ショーン・ルース</h1>
        <p id="profile" lang="en">I am a mobile and web developer based in Tokyo. I specialize in Ruby/Rails, Dart/Flutter, and web design. I
          speak fluent Japanese as well. Let's work together!</p>
          <p id="profile" lang="ja">東京在住のモバイル・ウエブ開発者のショーンと申します。Ruby/Rails、Dart/Flutter、ウエブデザインやAdobeの専門家です。英語と日本両方は対応可能ですのでぜひとも貴団体のプロジェクトを実現させてください。</p>
      </div>
      <div class="link-container">
        <div class="blurbox">
          <div class="linkbox">
              <a href="https://www.linkedin.com/in/sean-luse/"><%= image_tag("linkedin.png") %></a>
            <p><a href="https://www.linkedin.com/in/sean-luse/">LinkedIn</a></p>
          </div>
          <div class="linkbox">
              <a href="https://github.com/seanluse41"><%= image_tag("github-icon.png") %></a>
            <p><a href="https://github.com/seanluse41">Github</a></p>
          </div>
          <div class="linkbox">
            <a href="mailto:seanluse41@gmail.com"><%= image_tag("mail-white.png") %></a>
            <p><a href="mailto:seanluse41@gmail.com">Email</a></p>
          </div>
        </div>
      </div>
    </div>
    <%= yield %>
  </div>
</body>

</html>